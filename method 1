<button onclick="openBlankWithSite()">Open GN-Math</button>

<script>
function openBlankWithSite() {
    let win = window.open("about:blank", "_blank");

    win.document.write(`
        <html>
        <head>
            <title>GN-Math</title>
            <style>
                body, html {
                    margin: 0;
                    padding: 0;
                    height: 100%;
                    width: 100%;
                    overflow: hidden;
                }
                iframe {
                    border: none;
                    width: 100%;
                    height: 100%;
                }
            </style>
        </head>
        <body>
            <iframe src="https://gn-math.dev/"></iframe>
        </body>
        </html>
    `);
}
</script>
